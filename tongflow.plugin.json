{
    "plugin": {
        "name": "InfiniteTalk",
        "description": "Audio-driven lip-sync — turn an audio track plus a video or image into a talking-head video.",
        "icon": "/plugins/tongflow-modal-infinitetalk.svg"
    },
    "env": [
        {
            "key": "MODAL_TOKEN_ID",
            "required": true,
            "description": "Modal token id",
            "url": "https://modal.com/settings/tokens"
        },
        {
            "key": "MODAL_TOKEN_SECRET",
            "required": true,
            "description": "Modal token secret (paired with MODAL_TOKEN_ID)"
        },
        {
            "key": "HF_TOKEN",
            "description": "Required to fetch the Wan2.1 / InfiniteTalk weights",
            "url": "https://huggingface.co/settings/tokens",
            "required": true
        },
        {
            "key": "TONGFLOW_MODAL_CALL_TIMEOUT_S",
            "default": "2400",
            "description": "Max seconds to wait for a Modal call"
        },
        {
            "key": "INFINITETALK_MAX_VIDEO_S",
            "default": "60",
            "description": "Max output video length in seconds"
        }
    ]
}
